{
  "private": true,
  "type": "module",
  "dependencies": {
    "hackmyresume": "1.9.0-beta",
    "jsonresume-theme-macchiato": "^1.1.0",
    "react": "^18.3.1",
    "resumed": "5.0.0"
  },
  "devDependencies": {
    "http-server": "^14.1.0",
    "nodemon": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "convert": "hackmyresume convert src/template/resume.json output/resume.json",
    "build": "resumed output/resume.json --theme jsonresume-theme-macchiato -o output/resume.html",
    "serve": "http-server output --open /resume.html",
    "watch": "nodemon --watch src/template --exec \"make build\""
  },
  "pnpm": {
    "patchedDependencies": {
      "hackmyresume": "patches/hackmyresume.patch"
    }
  }
}
